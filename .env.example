# Runtime configuration
DATABASE_URL="file:../shared/data/sqlite/local.db"
CMS_RUNTIME_TARGET="server"
CMS_DB_DRIVER="sqlite"
CMS_STORAGE_DRIVER="fs"
CMS_FILESYSTEM_STORAGE_DIR="../shared/uploads"
CMS_PUBLIC_UPLOADS_PATH="/uploads"
IMAGE_STORAGE_DRIVER="filesystem"
IMAGE_FILESYSTEM_DIR="../shared/uploads"
IMAGE_DELIVERY_MODE="ipx"

# Session Security (must be at least 32 characters)
SESSION_PASSWORD="your-super-secure-session-password-32-chars-minimum-required-here-for-production"

# Public site URL used in emails (logo/links)
SITE_URL="https://example.com"

# Facebook Integration (optional)
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_PAGE_ID="your_facebook_page_id"

# Google OAuth (for Gmail + Google Calendar in /admin/parametres)
# Create an OAuth 2.0 Client ID in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
# Required scopes are requested by the app during OAuth:
#   https://www.googleapis.com/auth/gmail.send
#   https://www.googleapis.com/auth/calendar
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://localhost:3000/api/auth/gmail/callback"

# Trust the local HTTPS development CA instead of disabling TLS verification globally.
NODE_EXTRA_CA_CERTS="./certificates/ca.crt"

RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Optional central registry
CMS_REGISTRY_URL=""
CMS_REGISTRY_API_KEY=""
CMS_INSTANCE_SLUG=""
CMS_RELEASE_CHANNEL="stable"
